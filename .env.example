# Environment Variables Template
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:1234@localhost:5432/school_db?schema=public"

# ─── Clerk Authentication ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
# Clerk — required for RBAC middleware
# In Clerk Dashboard → Sessions → Customize session token, add:
# { "metadata": { "role": "{{user.public_metadata.role}}" } }
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Dev-only: password for npm run sync-clerk (no # unquoted — # starts a comment in .env)
SYNC_DEFAULT_PASSWORD=CsolveSmsDev2026xR9k

# ─── Cloudinary (teacher/student photo uploads) ─────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Optional (future phases) ────────────────────────────────
# REDIS_URL=redis://localhost:6379
# RESEND_API_KEY=re_your_key
# SENTRY_DSN=https://your-sentry-dsn
# STRIPE_SECRET_KEY=sk_test_your_key
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
